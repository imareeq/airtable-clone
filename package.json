{
  "name": "lyra-takehome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev && bunx --bun prisma generate",
    "db:reset": "bunx --bun prisma migrate reset --force && bunx --bun prisma generate",
    "db:deploy": "bunx --bun prisma migrate deploy && bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:seed": "bunx --bun prisma db seed",
    "db:studio": "bunx --bun prisma studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
